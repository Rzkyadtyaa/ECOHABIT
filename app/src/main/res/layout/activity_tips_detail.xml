<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#43A047">

            <TextView
                android:id="@+id/txtEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💧"
                android:textSize="70sp"/>

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hemat Air"
                android:textStyle="bold"
                android:textSize="30sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="14dp"/>

        </LinearLayout>

        <!-- CONTENT CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            android:layout_marginTop="-40dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#FFFFFF">

                <!-- DESCRIPTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 Penjelasan"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#2E7D32"/>

                <TextView
                    android:id="@+id/txtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#616161"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="12dp"
                    android:text="Isi penjelasan tips."/>

                <!-- BENEFIT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌍 Manfaat"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="28dp"/>

                <TextView
                    android:id="@+id/txtBenefit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#616161"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="12dp"
                    android:text="Manfaat eco tips."/>

                <!-- HOW -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Cara Menerapkan"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="28dp"/>

                <TextView
                    android:id="@+id/txtHow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#616161"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginTop="12dp"
                    android:text="Cara menerapkan."/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>