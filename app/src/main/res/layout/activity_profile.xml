<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#43A047">

            <!-- AVATAR -->
            <TextView
                android:id="@+id/txtAvatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:gravity="center"
                android:text="🐼"
                android:textSize="60sp"
                android:background="#FFFFFF"
                android:textColor="#000000"/>

            <!-- USERNAME -->
            <EditText
                android:id="@+id/edtName"
                android:layout_width="250dp"
                android:layout_height="55dp"
                android:hint="Masukkan nama"
                android:textColor="#FFFFFF"
                android:textColorHint="#E8F5E9"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:layout_marginTop="16dp"/>

            <Button
                android:id="@+id/btnSaveName"
                android:layout_width="200dp"
                android:layout_height="55dp"
                android:text="Simpan Nama"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#2E7D32"/>

        </LinearLayout>

        <!-- PROFILE CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#FFFFFF">

                <!-- LEVEL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏆 Eco Level"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#2E7D32"/>

                <TextView
                    android:id="@+id/txtLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌱 Beginner"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#43A047"
                    android:layout_marginTop="10dp"/>

                <!-- PROGRESS -->
                <ProgressBar
                    android:id="@+id/progressLevel"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    android:max="100"
                    android:progress="40"
                    android:layout_marginTop="16dp"/>

                <!-- POINT -->
                <TextView
                    android:id="@+id/txtPoint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 0 Point"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginTop="20dp"/>

                <!-- BADGE -->
                <TextView
                    android:id="@+id/txtBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏅 Earth Beginner"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:layout_marginTop="14dp"/>

                <!-- MOTIVATION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌍 Every small habit makes Earth better."
                    android:textSize="15sp"
                    android:textColor="#757575"
                    android:layout_marginTop="24dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- AVATAR SELECT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎨 Choose Avatar"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#2E7D32"
            android:layout_marginStart="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp">

            <Button
                android:id="@+id/btnPanda"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="🐼"
                android:textSize="24sp"/>

            <Button
                android:id="@+id/btnFox"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="🦊"
                android:textSize="24sp"
                android:layout_marginStart="10dp"/>

            <Button
                android:id="@+id/btnCat"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="🐱"
                android:textSize="24sp"
                android:layout_marginStart="10dp"/>

            <Button
                android:id="@+id/btnFrog"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="🐸"
                android:textSize="24sp"
                android:layout_marginStart="10dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>