<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Achievements"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"/>

        <!-- FIRST HABIT -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFirst"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:gravity="center"
                    android:text="🌱"
                    android:textSize="38sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First Habit"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete your first eco habit"
                        android:textSize="15sp"
                        android:textColor="#757575"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/txtFirst"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCKED"
                    android:textStyle="bold"
                    android:textColor="#E53935"
                    android:textSize="14sp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- GREEN WARRIOR -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWarrior"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:gravity="center"
                    android:text="🏆"
                    android:textSize="38sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Green Warrior"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reach 150 eco points"
                        android:textSize="15sp"
                        android:textColor="#757575"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/txtWarrior"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCKED"
                    android:textStyle="bold"
                    android:textColor="#E53935"
                    android:textSize="14sp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ECO LEGEND -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardLegend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:gravity="center"
                    android:text="🌍"
                    android:textSize="38sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Eco Legend"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reach 500 eco points"
                        android:textSize="15sp"
                        android:textColor="#757575"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/txtLegend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCKED"
                    android:textStyle="bold"
                    android:textColor="#E53935"
                    android:textSize="14sp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>